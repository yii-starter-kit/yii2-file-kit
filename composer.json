{
    "name": "yii2-starter-kit/yii2-file-kit",
    "description": "Yii2 file upload and storage kit",
    "type": "yii2-extension",
    "license": "BSD-3-Clause",
    "authors": [
        {
            "name": "Eugene Terentev",
            "email": "eugene@terentev.net"
        },
        {
            "name": "Victor Gonzalez",
            "email": "victor@vgr.cl"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "yiisoft/yii2-jui": "^2.0.0",
        "league/flysystem": "^3.0",
        "npm-asset/blueimp-file-upload": "^9.7.0",
        "rmrevin/yii2-fontawesome": "^3.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": { "trntv\\filekit\\": "src/" }
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ],
    "scripts": {
        "test": "vendor/bin/phpunit"
    },
    "config": {
        "allow-plugins": {
            "yiisoft/yii2-composer": true
        }
    }
}
